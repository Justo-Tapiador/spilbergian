# ─────────────────────────────────────────────────────────────────────
# PREDATOR JUNGLE v3.0 "Spilbergian" — Environment Variables
# ─────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your API keys.
# All variables are optional — Spilbergian will gracefully degrade to
# placeholders for any provider that is not configured.

# ── LLM (scriptwriting, planning) ────────────────────────────────────
# Either set ZAI_API_KEY (uses z-ai-web-dev-sdk) or OPENAI_API_KEY with
# an OpenAI-compatible endpoint (z.ai, OpenAI, Ollama, LM Studio, etc.)
ZAI_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.z.ai/api/paas/v4
LLM_MODEL=glm-4.6

# ── Video providers (priority order set in config/default.json) ──────
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=
META_AI_API_KEY=
KLING_API_KEY=
RUNWAY_API_KEY=
PIKA_API_KEY=

# ── Audio providers ──────────────────────────────────────────────────
UDIO_API_KEY=
SUNO_API_KEY=
ELEVENLABS_API_KEY=

# ── Whisper (voice commands) ─────────────────────────────────────────
# If OPENAI_API_KEY is set, Whisper API is used automatically.
# Otherwise, install whisper / whisper-cpp locally.
WHISPER_MODEL=base
WHISPER_LANGUAGE=es

# ── YouTube (OAuth credentials.json lives in data/youtube/) ──────────
# No env vars needed; just place credentials.json per config.
YOUTUBE_CHANNEL_ID=
YOUTUBE_CHANNEL_NAME=

# ── CapCut ───────────────────────────────────────────────────────────
# Optional: path to CapCut CLI binary (if installed).
CAPCUT_CLI_PATH=

# ── Agent configuration (overrides config/default.json) ──────────────
PREDATOR_AGENT__CREATIVE_TEMPERATURE=0.85
PREDATOR_SAFETY__SAFETY_LEVEL=standard
PREDATOR_LOGGING__LEVEL=info
SPILBERGIAN_VOICE__WHISPER__MODEL=base
SPILBERGIAN_VOICE__COMMAND_MODE=wake_word
SPILBERGIAN_YOUTUBE__DEFAULT_PRIVACY=private

# ── Runtime ──────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
